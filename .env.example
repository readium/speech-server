# ── Server ──
APP_ENV=development          # development | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
HOST=0.0.0.0                 # bind address
PORT=8000                    # listen port (1–65535)
API_V1_PREFIX=/v1            # URL prefix for versioned routes
WORKERS=1                    # uvicorn worker count; RAM = model_size × workers

# ── Auth (off by default for PoC) ──
API_KEY_ENABLED=false        # set true to require X-API-Key header on all routes
API_KEY=                     # required when API_KEY_ENABLED=true

# ── Concurrency ──
MAX_CONCURRENT_SYNTHESES=2   # semaphore bound; limits parallel CPU-bound inferences

# ── Cache (in-memory only for v1; no S3/GCS) ──
CACHE_ENABLED=true           # set false to disable caching entirely
CACHE_MAX_ITEMS=256          # max LRU entries; each entry is one audio response

# ── Providers (comma-separated list) ──
ENABLED_PROVIDERS=pocket     # pocket | kokoro | elevenlabs | azure
DEFAULT_PROVIDER=pocket      # must be one of ENABLED_PROVIDERS

# ── PocketTTS ──
POCKET_WEIGHTS_DIR=/app/assets/weights   # directory containing baked model weights
POCKET_DEFAULT_VOICE=alba               # fallback voice when none specified

# ── Kokoro (later) ──
KOKORO_MODEL_PATH=/app/assets/weights/kokoro-v1.0.onnx
KOKORO_VOICES_PATH=/app/assets/weights/voices-v1.0.bin

# ── Commercial proxy (later) ──
ELEVENLABS_API_KEY=          # ElevenLabs secret key
ELEVENLABS_BASE_URL=https://api.elevenlabs.io   # override for testing/staging
ELEVENLABS_PROXY_URL=        # optional outbound proxy (per-provider IP pinning)
AZURE_TTS_KEY=               # Azure Cognitive Services speech key
AZURE_TTS_REGION=            # Azure region, e.g. eastus
AZURE_PROXY_URL=             # optional outbound proxy for Azure

# ── Audio / ffmpeg ──
FFMPEG_BIN=ffmpeg            # path to ffmpeg binary
DEFAULT_AUDIO_FORMAT=mp3     # mp3 | wav | opus
DEFAULT_SAMPLE_RATE=24000    # Hz; native PocketTTS output rate
HTTP_TIMEOUT_SECONDS=30      # timeout for outbound HTTP calls (commercial providers)
